# =============================================================================
# Kryptalis - Environment Variables
# =============================================================================

# Database
DATABASE_URL="postgresql://kryptalis:kryptalis@localhost:5432/kryptalis?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# API
API_PORT=4000
API_URL="http://localhost:4000"

# Dashboard
NEXT_PUBLIC_API_URL="http://localhost:4000"
DASHBOARD_PORT=3000

# JWT
JWT_SECRET="change-me-in-production-use-a-strong-random-string"
JWT_REFRESH_SECRET="change-me-in-production-use-another-strong-random-string"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# Encryption
ENCRYPTION_KEY="change-me-32-char-encryption-key"

# Agent
AGENT_TOKEN="change-me-agent-token"

# Cloudflare (optional)
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_ZONE_ID=""

# Email (optional)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""

# Backups (optional)
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_REGION="auto"
