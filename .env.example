# =============================================================================
# Kryptalis — environment template
#
# Copy to `.env` and fill the REQUIRED secrets before `./install.sh`.
# Anything marked "optional" can stay empty until you need that feature.
#
# To generate every required random secret in one shot:
#
#   openssl rand -hex 32       # 64-char hex — use for *_SECRET fields
#   openssl rand -base64 32    # 44-char base64 — also fine
#
# NEVER commit `.env`. It is gitignored.
# =============================================================================

# ── REQUIRED — auth / crypto secrets ──────────────────────────────────────────

# Used to sign access JWTs. ≥ 32 random chars. Rotate by issuing a new value
# and bouncing the API; users get logged out and re-issued tokens on next login.
JWT_SECRET="REPLACE_ME_64_random_hex_chars_from_openssl_rand_hex_32"

# Used to sign refresh JWTs. MUST be different from JWT_SECRET.
JWT_REFRESH_SECRET="REPLACE_ME_64_different_random_hex_chars"

# AES-256-GCM key used to encrypt secrets at rest (env vars, git tokens, DB
# passwords). EXACTLY 32 characters. Losing this key = every encrypted column
# becomes unreadable. Back it up out-of-band before going to prod.
ENCRYPTION_KEY="REPLACE_ME_exactly_32_random_chars_X"

# Shared secret between the API and remote Kryptalis agents (MULTI mode).
# Leave the default in LOCAL mode — it isn't used.
AGENT_TOKEN="REPLACE_ME_random_string_for_agent_auth"

# ── REQUIRED — database / cache ───────────────────────────────────────────────

# Postgres for the API. The bundled docker-compose runs this for you on
# port 5432; if you're using your own Postgres, point this URL at it.
DATABASE_URL="postgresql://kryptalis:kryptalis@localhost:5432/kryptalis?schema=public"

# Redis for job queues + session state. Bundled compose runs this on 6379.
REDIS_URL="redis://localhost:6379"

# ── REQUIRED — public URLs ────────────────────────────────────────────────────

# Where the dashboard browser sends API calls. In LOCAL dev: localhost:4000.
# In prod behind Caddy on a real domain: https://api.your-domain.com (or
# whatever route you wire up). Used by the dashboard React app at build time.
NEXT_PUBLIC_API_URL="http://localhost:4000"

# The API uses this for absolute redirect URLs (OAuth callbacks, webhook URLs
# emitted in API responses). Match what users actually reach over the network.
PUBLIC_API_URL="http://localhost:4000"

# ── REQUIRED — ports (defaults are sensible) ──────────────────────────────────

API_PORT=4000
DASHBOARD_PORT=3000

# JWT token TTLs. Short access token (15m) + long refresh (7d) is the
# default — works for almost everyone. Raise the refresh TTL if you have
# long-lived browser sessions, lower it if you want frequent re-auth.
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# ── OPTIONAL — Cloudflare DNS automation ──────────────────────────────────────

# When set, the dashboard's "Domains" page can create + verify A records
# without leaving the UI. Token needs Zone:DNS:Edit on the zone(s) you'll
# attach. Leave empty to manage DNS by hand.
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_ZONE_ID=""

# ── OPTIONAL — outgoing email (notifications, password resets) ────────────────

# Plug in any SMTP provider (Mailgun, SES, your own Postfix). Without these
# the platform is silent on user notifications — perfectly fine for solo use.
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""

# ── OPTIONAL — S3-compatible backups (Backblaze B2, R2, AWS, MinIO) ───────────

# Used by the /dashboard/backups page. S3_ENDPOINT is the API URL of your
# bucket provider (R2: https://<account>.r2.cloudflarestorage.com, AWS: leave
# empty). All four S3_* fields must be set together or none.
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_REGION="auto"
