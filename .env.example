# =============================================================================
# Kryptalis — environment template
#
# `install.sh` GENERATES a production `.env` for you with random secrets —
# you normally never copy this file on a server. This template documents
# every variable the stack actually reads, mostly for local development
# (API + dashboard running outside Docker via `pnpm dev`).
#
# To generate a random secret:
#
#   openssl rand -hex 32       # 64-char hex — use for *_SECRET fields
#   openssl rand -hex 16       # 32-char hex — ENCRYPTION_KEY minimum
#
# NEVER commit `.env`. It is gitignored.
# =============================================================================

# ── REQUIRED — auth / crypto secrets ──────────────────────────────────────────

# Used to sign access JWTs. ≥ 32 random chars. Rotate by issuing a new value
# and bouncing the API; users get logged out and re-issued tokens on next login.
JWT_SECRET="REPLACE_ME_64_random_hex_chars_from_openssl_rand_hex_32"

# Used to sign refresh JWTs. MUST be different from JWT_SECRET.
JWT_REFRESH_SECRET="REPLACE_ME_64_different_random_hex_chars"

# Encrypts secrets at rest (SMTP password, git tokens, DB passwords) with
# AES-256-GCM; the actual AES key is derived from this value via scrypt.
# ≥ 32 characters (openssl rand -hex 16). Losing this key = every encrypted
# column becomes unreadable. Back it up out-of-band before going to prod.
ENCRYPTION_KEY="REPLACE_ME_at_least_32_random_chars"

# Postgres superuser password. Docker-compose REQUIRES this (${VAR:?} guard).
# Baked into the Postgres data volume on FIRST init — changing it later
# requires wiping the volume (KRYPTALIS_RESET=1 ./install.sh).
POSTGRES_PASSWORD="REPLACE_ME_random_db_password"

# ── REQUIRED — database (dev outside Docker) ─────────────────────────────────

# Postgres for the API. Inside the bundled compose this is set automatically
# from POSTGRES_PASSWORD; only set it yourself for the local pnpm dev loop
# (docker/docker-compose.dev.yml exposes 127.0.0.1:5432 with kryptalis/kryptalis).
DATABASE_URL="postgresql://kryptalis:kryptalis@localhost:5432/kryptalis?schema=public"

# ── REQUIRED — public URLs ────────────────────────────────────────────────────

# Where the dashboard browser sends API calls. In LOCAL dev: localhost:4000.
# In prod behind Caddy on a real domain: https://api.your-domain.com.
# Inlined into the dashboard at BUILD time (NEXT_PUBLIC_*) — changing it
# requires a dashboard rebuild (install.sh handles that).
NEXT_PUBLIC_API_URL="http://localhost:4000"

# The API uses this for absolute URLs (webhook URLs in API responses, CORS
# allowlist derivation). Match what users actually reach over the network.
PUBLIC_API_URL="http://localhost:4000"

# The API uses this to build CTA links inside notification emails (and
# anywhere it needs the dashboard's public origin). In prod behind a domain:
# https://panel.your-domain.com.
PUBLIC_DASHBOARD_URL="http://localhost:3000"

# ── OPTIONAL — network binds / ports ─────────────────────────────────────────

API_PORT=4000
# Host port the dashboard is published on (container always listens on 3000).
DASHBOARD_PORT=3000
# Host port for the bundled SFTP service (container always listens on 22).
SFTP_PORT=2222
# Once a domain fronts the dashboard/API through Caddy, bind them to
# loopback so direct port access stops bypassing TLS:
#DASHBOARD_BIND=127.0.0.1
#API_BIND=127.0.0.1

# JWT token TTLs. Short access token (15m) + long refresh (7d) is the
# default — works for almost everyone.
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# ── OPTIONAL — CORS / Swagger ────────────────────────────────────────────────

# Comma-separated explicit allowlist of browser origins. When unset, the
# API derives it from PUBLIC_API_URL + local dev origins.
#CORS_ORIGINS="https://panel.example.com"
# Expose Swagger docs (/api/docs) in production. Off by default.
#SWAGGER_PUBLIC=true

# ── OPTIONAL — SSL / backups ─────────────────────────────────────────────────

# Email used for Let's Encrypt registration by Caddy.
#ACME_EMAIL="ops@example.com"
# 32-byte hex key for AES-256-GCM backup encryption. Separate from
# ENCRYPTION_KEY so backup access can be siloed from app secrets. Can also
# be set later from Admin → System Config (stored encrypted in DB).
#BACKUP_ENCRYPTION_KEY=""

# ── OPTIONAL — outgoing email (legacy env fallback) ──────────────────────────

# SMTP is normally configured from Admin → System Config (live-editable,
# password encrypted at rest). These env vars are the LEGACY fallback used
# only when no SystemSetting row exists.
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# ── OPTIONAL — git providers ─────────────────────────────────────────────────

# GitHub OAuth app client id for the "connect GitHub" flow. A shared default
# is baked into the API; set this to use your own OAuth app per install.
#GITHUB_OAUTH_CLIENT_ID=""

# ── Auto-update (compose-injected, set by install.sh) ────────────────────────

# Branch the auto-updater tracks. Default: main.
#KRYPTALIS_BRANCH=main
# Override the auto-detected GitHub owner/repo (useful for forks).
#KRYPTALIS_GITHUB_REPO=""

# ── ADVANCED — rarely needed, read directly by the API ───────────────────────

# Name of the Caddy data volume (mail-server cert lookups). Only set if you
# renamed the compose project and the auto-detection fails.
#CADDY_DATA_VOLUME=""
# Comma-separated container names the API refuses to stop/remove, in
# addition to the built-in kryptalis-* system containers.
#KRYPTALIS_PROTECTED_CONTAINERS=""
# Path of the docker-compose.override.yml the reverse-proxy writes for
# extra published Caddy ports. Default: /app/install-root/docker-compose.override.yml.
#KRYPTALIS_COMPOSE_OVERRIDE=""
