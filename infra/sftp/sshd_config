# DockControl SFTP daemon config.
#
# Two principles:
#   1. SFTP-only — every non-root login is forced to internal-sftp.
#      No shell, no port forward, no agent forward, no X11.
#   2. Chrooted — each account gets a per-user drop-in in
#      /etc/ssh/sshd_config.d/<user>.conf that points ChrootDirectory
#      straight at the app's data path (host-fs dir for git deploys,
#      Docker volume's _data dir for marketplace/image apps). The
#      drop-in also re-asserts ForceCommand + forwarding bans so the
#      policy travels with the account regardless of any future
#      global default change.

Port 22
AddressFamily any
ListenAddress 0.0.0.0
ListenAddress ::

# Host keys generated at first boot by the entrypoint.
HostKey /etc/ssh/ssh_host_ed25519_key
HostKey /etc/ssh/ssh_host_rsa_key

# Logging — every login attempt visible in `docker logs`.
SyslogFacility AUTH
LogLevel VERBOSE

# Authentication
PermitRootLogin no
PasswordAuthentication yes
PubkeyAuthentication yes
PermitEmptyPasswords no
ChallengeResponseAuthentication no
KbdInteractiveAuthentication no
# UsePAM intentionally omitted. Alpine's stock `openssh` binary is
# built without PAM support, so the directive prints
# "Unsupported option UsePAM" on every config reload. We don't need
# PAM either way — sshd reads /etc/shadow directly via crypt(3), and
# our chpasswd flow writes SHA-512 crypt entries there. PAM would
# only matter for session-level integrations we don't have
# (pam_limits, pam_mkhomedir, etc.).
# Brute-force defense: allow 3 auth failures per connection before
# tarpitting. MaxStartups raised because Filezilla aggressively
# parallelizes operations (it opens up to 10 connections at once,
# which the default 10:30:60 cap would refuse with ECONNREFUSED).
# 100 simultaneous unauthenticated still cuts off real botnets.
MaxAuthTries 3
MaxStartups 100:30:200
# Drop idle sessions after 5 minutes so FileZilla forgetting to
# disconnect doesn't keep slots tied up.
ClientAliveInterval 60
ClientAliveCountMax 5

# Force SFTP-only for everyone except root (which is locked anyway).
Subsystem sftp internal-sftp -l VERBOSE

# Per-user sshd_config includes. The DockControl API drops one .conf
# file per account here with BOTH the chroot path AND the sftp/lock
# directives. We DO NOT add a Match Group block here — sshd evaluates
# Match in order and stops at the first match, so a global Match
# Group would silently shadow every per-user Include below it (the
# user would get the group's ChrootDirectory %h pointing at an
# unprepared /home/<user> dir, triggering "bad ownership or modes
# for chroot directory" auth failures).
#
# Load order matters: Include must come BEFORE any catch-all Match
# block or sshd ignores the per-user files.
Include /etc/ssh/sshd_config.d/*.conf
