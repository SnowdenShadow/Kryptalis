generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users ───────────────────────────────────────────────────────────

model User {
  id               String     @id @default(cuid())
  name             String
  email            String     @unique
  password         String
  role             Role       @default(USER)
  status           UserStatus @default(ACTIVE)
  twoFactorEnabled Boolean    @default(false)
  twoFactorSecret  String?
  lastLoginAt      DateTime?
  // Account-level brute-force lockout. failedLoginAttempts increments on
  // every bad password OR bad TOTP code (after the password passed). At
  // threshold (5) the account is locked for 15 min via lockedUntil so
  // credential stuffing across rotated IPs can't grind the password or
  // TOTP space.
  failedLoginAttempts Int @default(0)
  lockedUntil         DateTime?
  // Per-user notification channel preferences, keyed event → channel → bool
  // (e.g. { deployFail: { email: true, slack: false } }). Edited via
  // PUT /users/me/notification-preferences.
  notificationPrefs Json?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  sessions            Session[]
  projects            Project[]
  deployments         Deployment[]
  auditLogs           AuditLog[]
  gitProviders        GitProvider[]
  memberships         ProjectMember[]       @relation("ProjectMembership")
  passwordResetTokens PasswordResetToken[]
  backupCodes         TwoFactorBackupCode[]
  verificationTokens  EmailVerificationToken[]
  sftpAccounts        SftpAccount[]
  notifications       Notification[]

  @@map("users")
}

model GitProvider {
  id        String   @id @default(cuid())
  userId    String
  provider  String
  name      String
  token     String
  // 'PAT' = legacy personal access token, 'OAUTH' = OAuth flow (auto-refresh)
  authMode  String   @default("PAT")
  // OAuth state — only set when authMode='OAUTH'. Stored encrypted via EncryptionService.
  refreshToken String?
  expiresAt DateTime?
  scopes    String?
  username  String?
  avatarUrl String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("git_providers")
}

enum Role {
  SUPERADMIN
  ADMIN
  USER
  VIEWER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  PENDING_VERIFICATION
  // Set at registration when the `require_admin_approval` SystemSetting is
  // true. Login is refused (403) until an admin flips the user to ACTIVE
  // via PATCH /admin/users/:id/status.
  PENDING_APPROVAL
}

model SystemSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("system_settings")
}

model Session {
  id                String   @id @default(cuid())
  userId            String
  // Stored as sha256(refreshToken). Never store raw. DB leak = no usable tokens.
  refreshTokenHash  String   @unique
  // Rotation chain — every refresh creates a new session and marks the old
  // one as ROTATED. Re-using a ROTATED/REVOKED token revokes the whole
  // family (RFC 6819 §5.2.2.3 — refresh token replay detection).
  familyId          String
  status            SessionStatus @default(ACTIVE)
  replacedById      String?
  userAgent         String?
  ipAddress         String?
  expiresAt         DateTime
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@map("sessions")
}

enum SessionStatus {
  /** Briefly held during rotation CAS — never accepts a refresh. */
  PENDING
  ACTIVE
  ROTATED
  REVOKED
}

// Password-reset tokens. Stored as sha256 hash so DB leak doesn't yield
// usable reset links. Tokens are single-use (usedAt marks consumption)
// and expire after ~30 minutes.
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// Email verification tokens. Stored as sha256 hash; single-use; 24h expiry.
// Issued at register() when status=PENDING_VERIFICATION, consumed by
// /auth/verify-email which flips status to ACTIVE and issues a token pair.
model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

// TOTP backup codes (10 codes per user, bcrypt-hashed). Used once.
model TwoFactorBackupCode {
  id        String   @id @default(cuid())
  userId    String
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("two_factor_backup_codes")
}

// ─── Servers ─────────────────────────────────────────────────────────

model Server {
  id           String       @id @default(cuid())
  name         String
  host         String
  port         Int          @default(22)
  username     String       @default("root")
  status       ServerStatus @default(PROVISIONING)
  os           String?
  arch         String?
  totalMemory  BigInt?
  totalDisk    BigInt?
  cpuCores     Int?
  agentVersion String?
  lastSeenAt   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  projects     Project[]
  applications Application[]
  agentTokens  AgentToken[]
  databases    Database[]
  backups      Backup[]
  alertRules   AlertRule[]
  metrics      ServerMetric[]
  tasks        AgentTask[]

  @@map("servers")
}

enum ServerStatus {
  ONLINE
  OFFLINE
  PROVISIONING
  PENDING_INSTALL
  MAINTENANCE
  ERROR
}

model AgentToken {
  id        String   @id @default(cuid())
  serverId  String
  token     String   @unique
  expiresAt DateTime?
  createdAt DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId])
  @@map("agent_tokens")
}

// ─── Projects ────────────────────────────────────────────────────────

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  serverId    String
  userId      String
  // Per-project file storage quota in bytes. Default 10 GiB. The Files
  // module enforces this on every write (upload/create/mkdir-with-file)
  // by computing actual on-disk usage with a 60s-TTL cache. We do NOT
  // persist storageUsedBytes — it's derived on demand to avoid drift
  // between DB rows and the real filesystem state.
  storageQuotaBytes BigInt? @default(10737418240)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  server       Server          @relation(fields: [serverId], references: [id], onDelete: Cascade)
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]
  databases    Database[]
  domains      Domain[]
  mailboxes    Mailbox[]
  members      ProjectMember[]
  sftpAccounts SftpAccount[]
  backups      Backup[]
  backupStorage ProjectBackupStorage?

  @@index([serverId])
  @@index([userId])
  @@map("projects")
}

// ─── Per-project remote backup storage (S3-compatible) ───────────────
//
// Lets each project bring its OWN S3 / R2 / B2 bucket for remote backups
// instead of sharing the platform-wide admin config. The secret key is
// encrypted at rest (EncryptionService envelope). One row per project
// (1-1). When absent, the backup engine falls back to the global
// SystemSetting s3_* config (admin-managed) or LOCAL.
model ProjectBackupStorage {
  id           String   @id @default(cuid())
  projectId    String   @unique
  // S3 / R2 / B2 — which remote target these credentials are for.
  target       BackupTarget
  endpoint     String
  bucket       String
  region       String?
  accessKey    String
  // AES-256-GCM envelope (never stored or returned in plaintext).
  secretKeyEnc String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_backup_storage")
}

model ProjectMember {
  id         String      @id @default(cuid())
  projectId  String
  userId     String
  role       ProjectRole @default(VIEWER)
  invitedById String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation("ProjectMembership", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@map("project_members")
}

enum ProjectRole {
  OWNER
  ADMIN
  DEVELOPER
  VIEWER
}

// ─── Applications ────────────────────────────────────────────────────

model Application {
  id                String          @id @default(cuid())
  // Canonical name — drives slugify(), container_name, on-disk dir. Locked
  // after creation: changing it would break stop/start/restart/logs (they
  // resolve paths from slugify(name)). To rename for display purposes,
  // use displayName instead.
  name              String
  // Optional human-friendly name shown in the UI. Falls back to `name` when
  // null. Safe to change anytime — purely cosmetic, no infra impact.
  displayName       String?
  projectId         String
  // Per-app server placement. NULL = inherit the project's serverId (the
  // project server is a DEFAULT, not a constraint — apps in one project can
  // run on different machines). Resolution: resolveAppServer() — every
  // deploy / lifecycle / reverse-proxy path goes through it.
  serverId          String?
  framework         AppFramework    @default(DOCKER)
  status            AppStatus       @default(STOPPED)
  gitUrl            String?
  gitBranch         String?         @default("main")
  gitProvider       GitProviderType?
  gitProviderId     String?
  dockerImage       String?
  dockerComposeFile String?
  buildCommand      String?
  startCommand      String?
  port              Int?
  // True when the user explicitly chose this port at install time. Caddy
  // routes traffic to https://<domain>:<port> instead of https://<domain>
  // when this is set, so the user-picked port shows up in the final URL.
  customPort        Boolean         @default(false)
  // Internal container port — what the app actually listens on inside its
  // Docker container (e.g. 80 for nginx, 5000 for a Flask app, 9443 for
  // Portainer). When `containerName` + `containerPort` are set, Caddy
  // reverse_proxies to <containerName>:<containerPort> over the shared
  // docker network — no host-side port publish needed, so multiple custom
  // ports + Let's Encrypt certs work.
  containerName     String?
  containerPort     Int?
  // Optional host-port publish for apps that have NO domain. When set,
  // docker-compose publishes "hostPort:containerPort" so the user can
  // reach the app at http://<serverIp>:<hostPort> without DNS/TLS. The
  // platform refuses values that collide with reserved system ports
  // (3000 dashboard, 4000 API, 5432 postgres, 6379 redis, 80/443 caddy).
  hostPort          Int?
  envVars           Json?
  portMapping       Json?
  webhookSecret     String?
  autoDeploy        Boolean         @default(true)
  // PHP runtime version for PHP_SITE apps (e.g. "8.3"). Selected at create
  // time, baked into the php:<version>-apache image as a build ARG. NULL for
  // every other framework. Changing it triggers an image rebuild on redeploy.
  phpVersion        String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  project          Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // SetNull: deleting a server must not delete the apps that ran on it —
  // they fall back to the project's server and can be redeployed there.
  server           Server?             @relation(fields: [serverId], references: [id], onDelete: SetNull)
  deployments      Deployment[]
  domains          Domain[]
  portBindings     DomainPortBinding[]
  databases        Database[]
  sftpAccounts     SftpAccount[]
  cronJobs         CronJob[]

  @@index([projectId])
  @@index([serverId])
  @@map("applications")
}

enum AppFramework {
  NEXTJS
  REACT
  VUE
  ANGULAR
  NESTJS
  EXPRESS
  LARAVEL
  SYMFONY
  DJANGO
  FLASK
  FASTAPI
  STATIC
  DOCKER
  DOCKER_COMPOSE
  // Classic "shared hosting" site: an Apache + PHP container (selectable PHP
  // version) serving files the user uploads via SFTP, with a live bind-mounted
  // docroot — no git repo, no rebuild on file change.
  PHP_SITE
}

enum AppStatus {
  RUNNING
  STOPPED
  BUILDING
  DEPLOYING
  ERROR
  UNKNOWN
}

enum GitProviderType {
  GITHUB
  GITLAB
  BITBUCKET
  FORGEJO
  GITEA
}

// ─── Deployments ─────────────────────────────────────────────────────

model Deployment {
  id            String           @id @default(cuid())
  applicationId String
  status        DeploymentStatus @default(PENDING)
  commitSha     String?
  commitMessage String?
  buildLogs     String?
  deployLogs    String?
  duration      Int?
  triggeredById String
  startedAt     DateTime?
  finishedAt    DateTime?
  createdAt     DateTime         @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  triggeredBy User        @relation(fields: [triggeredById], references: [id])

  @@index([applicationId])
  @@map("deployments")
}

enum DeploymentStatus {
  PENDING
  BUILDING
  DEPLOYING
  RUNNING
  FAILED
  CANCELLED
  ROLLING_BACK
  ROLLED_BACK
}

// ─── Domains ─────────────────────────────────────────────────────────

model Domain {
  id            String       @id @default(cuid())
  domain        String       @unique
  projectId     String?
  // The "main" application on this domain — served on :443 in clean-URL mode.
  // Additional apps can co-host on the same domain via DomainPortBinding
  // (each on its own custom port).
  applicationId String?
  status        DomainStatus @default(PENDING)
  sslStatus     SSLStatus    @default(PENDING)
  sslExpiresAt  DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  project      Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  application  Application?       @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  portBindings DomainPortBinding[]
  dnsRecords   DNSRecord[]
  certificate  SSLCertificate?
  mailboxes    Mailbox[]
  aliases      EmailAlias[]
  mailServer   MailServer?

  @@index([projectId])
  @@index([applicationId])
  @@map("domains")
}

/**
 * One <domain, port> binding to an application. Lets multiple apps share a
 * single hostname when each lives on its own port.
 *
 * Examples for the apex test.webelis.com:
 *   - (test.webelis.com, 443, app=WordPress)  — the "main" app, also tracked
 *                                                via Domain.applicationId
 *   - (test.webelis.com, 9443, app=Portainer)
 *   - (test.webelis.com, 8080, app=Ghost)
 *
 * Caddy reads this table to emit one `<domain>:<port>` site block per row.
 * The (domainId, port) pair is unique — two apps can't fight over the same
 * exposed port on the same hostname.
 */
model DomainPortBinding {
  id            String   @id @default(cuid())
  domainId      String
  applicationId String
  port          Int
  createdAt     DateTime @default(now())

  domain      Domain      @relation(fields: [domainId], references: [id], onDelete: Cascade)
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([domainId, port])
  @@index([applicationId])
  @@map("domain_port_bindings")
}

model MailServer {
  id           String           @id @default(cuid())
  domainId     String           @unique
  status       MailServerStatus @default(STOPPED)
  smtpPort     Int              @default(2525)
  submissionPort Int            @default(587)
  imapPort     Int              @default(1143)
  imapsPort    Int              @default(993)
  smtpsPort    Int              @default(465)
  dkimSelector String           @default("dockcontrol")
  dkimPublicKey String?
  dkimPrivateKey String?         // PEM-encoded, encrypted at rest in V4
  hostname     String?
  lastError    String?
  // ── antispam config (applied to the generated compose + rspamd files on
  //    each (re)deploy). Defaults = current behaviour: rspamd + fail2ban on,
  //    no greylisting/antivirus, mark (don't reject) above the threshold.
  spamPreset    String  @default("standard") // standard | strict | maximum | custom
  greylisting   Boolean @default(false)      // Postgrey
  antivirus     Boolean @default(false)      // ClamAV (heavy ~1GB RAM)
  spamAction    String  @default("add_header") // add_header | reject
  spamThreshold Float   @default(6)          // rspamd reject score
  whitelist     String?                      // newline-separated senders/domains
  blacklist     String?                      // newline-separated senders/domains
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  domain Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@map("mail_servers")
}

enum MailServerStatus {
  STOPPED
  DEPLOYING
  RUNNING
  ERROR
}

// ─── Email Hosting ───────────────────────────────────────────────────

model Mailbox {
  id          String        @id @default(cuid())
  address     String        @unique
  localPart   String
  domainId    String
  projectId   String?
  passwordHash String
  quotaMb     Int           @default(2048)
  usedMb      Int           @default(0)
  status      MailboxStatus @default(ACTIVE)
  forwardTo   String?
  catchAll    Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  domain  Domain         @relation(fields: [domainId], references: [id], onDelete: Cascade)
  project Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  aliases EmailAlias[]   @relation("MailboxAliases")

  @@index([domainId])
  @@index([projectId])
  @@map("mailboxes")
}

enum MailboxStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

model EmailAlias {
  id        String   @id @default(cuid())
  address   String   @unique
  domainId  String
  targetMailboxId String?
  forwardTo String?
  createdAt DateTime @default(now())

  domain  Domain   @relation(fields: [domainId], references: [id], onDelete: Cascade)
  mailbox Mailbox? @relation("MailboxAliases", fields: [targetMailboxId], references: [id], onDelete: SetNull)

  @@index([domainId])
  @@index([targetMailboxId])
  @@map("email_aliases")
}

enum DomainStatus {
  ACTIVE
  PENDING
  ERROR
}

enum SSLStatus {
  ACTIVE
  PENDING
  EXPIRED
  ERROR
}

model DNSRecord {
  id       String @id @default(cuid())
  domainId String
  type     String
  name     String
  content  String
  ttl      Int    @default(3600)
  priority Int?
  proxied  Boolean @default(false)

  domain Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@index([domainId])
  @@map("dns_records")
}

model SSLCertificate {
  id          String   @id @default(cuid())
  domainId    String   @unique
  certificate String
  privateKey  String
  chain       String?
  issuedAt    DateTime
  expiresAt   DateTime
  // Set when an "expiring soon" notification was dispatched for the current
  // expiry window. The notifier compares it against the window start, so a
  // renewal (expiresAt pushed forward) re-arms the alert automatically.
  expiryNotifiedAt DateTime?
  createdAt   DateTime @default(now())

  domain Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@map("ssl_certificates")
}

// ─── Databases ───────────────────────────────────────────────────────

model Database {
  id            String   @id @default(cuid())
  name          String
  type          DbType
  serverId      String
  projectId     String?
  applicationId String?
  host          String   @default("localhost")
  port          Int
  username      String
  password      String
  size          BigInt?
  // True when this row was created by the auto-importer (compose / marketplace
  // bundled DBs). Lifecycle is owned by the parent app — start/stop/remove
  // cascade through the app, NOT through the /databases dialog. The UI shows
  // a badge so users understand they shouldn't try to manage it standalone.
  autoImported  Boolean  @default(false)
  // The service name (`db`, `mariadb`, `prestashop-db-xxx`) inside the parent
  // compose project. Used as the idempotency key on redeploy so we update
  // the existing row instead of inserting a duplicate every redeploy.
  serviceName   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  server      Server       @relation(fields: [serverId], references: [id], onDelete: Cascade)
  project     Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  // Auto-imported DBs follow their parent app — Cascade so removing the
  // app drops them. Manually-created DBs use applicationId only as a
  // soft link (SetNull) so the registry row survives the app deletion;
  // we run an extra prisma.database.deleteMany({ applicationId, autoImported })
  // before deleting the app to cover the cascade for those.
  application Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@unique([applicationId, serviceName])
  @@index([serverId])
  @@index([projectId])
  @@index([applicationId])
  @@map("databases")
}

// ─── SFTP accounts ────────────────────────────────────────────────────
//
// User-issued SFTP/SSH credentials that map onto an existing app or
// project scope. The actual sshd lives in the dockcontrol-sftp container;
// SftpService writes /etc/passwd entries + chrooted home dirs based on
// this table at every change.
//
// Why a separate row instead of overloading ProjectMember?
//   - These are NON-INTERACTIVE creds (a tool like Filezilla connects;
//     no one types them into a browser). Different threat model.
//   - We want short-lived & rotatable independently of dashboard login.
//   - The chroot scope (single app vs single project) doesn't match
//     dashboard RBAC granularity.
//   - Tokens (hashed password / public key) live here; ProjectMember
//     would have to absorb a foreign-key to a separate creds table
//     anyway.

model SftpAccount {
  id            String   @id @default(cuid())
  username      String   @unique // sshd login name. Validated [a-z0-9_-]{3,32}.
  // bcrypt-hashed password (DockControl-internal verification). NULL when
  // the account is key-only.
  passwordHash  String?
  // AES-encrypted plaintext password — needed because OpenSSH/PAM in
  // the SFTP container uses crypt(3), not bcrypt, so we have to be
  // able to re-apply the password on container recreate via
  // `docker exec chpasswd`. Encrypted with EncryptionService (same
  // key envelope as DB passwords). NULL for key-only accounts.
  passwordEnc   String?
  // SSH public keys this account can use to authenticate. JSON array of
  // strings ("ssh-ed25519 AAAA... comment"). Each line is appended to
  // authorized_keys with no shell forced (we use ForceCommand internal-sftp
  // globally in sshd_config).
  publicKeys    Json    @default("[]")
  // Scope: account is chrooted to either an app's appDir or a project's
  // root. Exactly one of (applicationId, projectId) is set.
  applicationId String?
  projectId     String?
  // Permission level INSIDE the chroot. READ → ChrootDirectory mounted
  // read-only via bindfs. WRITE → r/w bindmount. ADMIN is currently
  // identical to WRITE; reserved for future "can manage other SFTP
  // accounts" semantics.
  permission    SftpPermission @default(WRITE)
  // Disabled accounts stay in the table for audit but get pulled from
  // sshd_config on the next sync. UI lets the user re-enable.
  disabled      Boolean  @default(false)
  // Shell access toggle.
  //
  // false (default) — pure SFTP. ForceCommand=internal-sftp + the
  // user's login shell is /bin/false. Putty/Filezilla still work via
  // SFTP, but `ssh` falls back to "This service allows sftp
  // connections only."
  //
  // true — Putty/ssh gets an interactive bash shell INSIDE the sftp
  // container's chroot (/home/<user>, with the app bind-mounted at
  // /home/<user>/app). No ForceCommand override, no chroot bypass —
  // the user still can't escape /home/<user>. Useful for editing
  // configs inline, running build scripts, etc.
  //
  // Grant is per-account and audited — we don't expose host-level
  // shell, only the SFTP container's chroot.
  allowShell    Boolean  @default(false)
  // Optional auto-expiry. NULL = never expires. Past expiry → sync
  // treats the row as disabled.
  expiresAt     DateTime?
  // Last successful connection. Updated by the sshd PAM-like wrapper
  // on each session; null until first login. Drives the "stale account"
  // hint in the UI.
  lastUsedAt    DateTime?
  // Who created it — feeds the audit trail and "rotated by X" hints.
  createdById   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  application Application? @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  project     Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy   User         @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([applicationId])
  @@index([projectId])
  @@map("sftp_accounts")
}

enum SftpPermission {
  READ
  WRITE
  ADMIN
}

enum DbType {
  POSTGRESQL
  MYSQL
  MARIADB
  REDIS
  KEYDB
  DRAGONFLY
  MONGODB
  CLICKHOUSE
}

// ─── Backups ─────────────────────────────────────────────────────────

model Backup {
  id                  String       @id @default(cuid())
  name                String
  serverId            String
  // Optional PROJECT scope. When set, the backup dumps ONLY this project's
  // apps + databases + volumes (isolation between projects). NULL = legacy
  // behaviour: the WHOLE server (every project on it) — kept for admin-wide
  // snapshots and backward compatibility with rows created before this field.
  projectId           String?
  target              BackupTarget @default(LOCAL)
  status              BackupStatus @default(PENDING)
  size                BigInt?
  // sha256 of the FINAL on-disk dump (post-encryption if encryptedAt=true).
  // Computed at write time, re-verified on restore — mismatch → refuse to
  // restore (corruption / tampering detection).
  sha256              String?
  // True when the dump on disk is AES-256-GCM encrypted with BACKUP_ENCRYPTION_KEY.
  // Recorded explicitly so a restore knows whether to decrypt first, and so
  // operators can see at a glance which rows are siloed from main DB access.
  encryptedAt         Boolean      @default(false)
  // Final on-disk size in bytes (matches whatever sha256 was computed over).
  // Surfaced in the UI alongside the existing legacy `size` field.
  sizeBytes           BigInt?
  // Basename of the dump archive (e.g. "<id>.tar.gz"). LOCAL targets resolve
  // the full path as <DATA_DIR>/backups/<filename>; remote targets use it as
  // the object key suffix under dockcontrol-backups/<id>/.
  filename            String?
  // For remote (S3/R2/B2) backups: the EXACT storage coordinate the dump was
  // written to, pinned at finalize time as an AES-256-GCM encrypted JSON
  // (endpoint/bucket/region/accessKey/secretKey). Restore & delete resolve the
  // bucket from THIS, not from the live project config — so editing or removing
  // a project's storage later never re-points an existing backup at the wrong
  // bucket (which would make it unrestorable and orphan the real object). NULL
  // for LOCAL backups and for legacy rows created before this column (those
  // fall back to dynamic project/global resolution).
  storageConfigEnc    String?
  includeApplications Boolean      @default(true)
  includeDatabases    Boolean      @default(true)
  includeVolumes      Boolean      @default(true)
  schedule            String?
  lastRunAt           DateTime?
  createdAt           DateTime     @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  // Deleting a project drops its scoped backup rows (the dump files are pruned
  // by the same retention path). Server-wide backups (projectId null) are
  // unaffected.
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([serverId])
  @@index([projectId])
  @@map("backups")
}

enum BackupTarget {
  LOCAL
  S3
  R2
  B2
}

enum BackupStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

// ─── Monitoring ──────────────────────────────────────────────────────

model ServerMetric {
  id         String   @id @default(cuid())
  serverId   String
  cpuPercent Float
  memoryUsed BigInt
  memoryTotal BigInt
  diskUsed   BigInt
  diskTotal  BigInt
  networkIn  BigInt
  networkOut BigInt
  timestamp  DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, timestamp])
  @@map("server_metrics")
}

model AlertRule {
  id        String       @id @default(cuid())
  name      String
  serverId  String
  metric    String
  threshold Float
  // Comparison operator. Default GTE because the original use case is
  // high-water-mark alerts ('CPU >= 90%'); LT/LTE enable floor-watching
  // ('free disk < 10%', 'requests/s dropped below 5').
  operator   AlertOperator @default(GTE)
  channel   AlertChannel @default(EMAIL)
  webhookUrl String?
  enabled   Boolean      @default(true)
  createdAt DateTime     @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId])
  @@map("alert_rules")
}

enum AlertOperator {
  GT
  GTE
  LT
  LTE
  EQ
}

enum AlertChannel {
  EMAIL
  DISCORD
  SLACK
  WEBHOOK
}

// ─── Agent Tasks ─────────────────────────────────────────────────────

model AgentTask {
  id          String     @id @default(cuid())
  serverId    String
  type        TaskType
  status      TaskStatus @default(QUEUED)
  payload     Json
  result      Json?
  error       String?
  createdAt   DateTime   @default(now())
  startedAt   DateTime?
  completedAt DateTime?

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, status])
  @@map("agent_tasks")
}

enum TaskType {
  DEPLOY
  BUILD
  START
  RESTART
  STOP
  REMOVE
  LOGS
  EXEC
  STATUS
  FILE_READ
  FILE_WRITE
  FILE_LIST
  FILE_DELETE
  DISK_USAGE
  SFTP_SYNC
  BACKUP
  SSL_ISSUE
  SSL_RENEW
  DNS_UPDATE
  MONITOR
  VOLUME_EXPORT
  VOLUME_IMPORT
  VOLUME_LIST
  RESTORE
}

enum TaskStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

// ─── Audit Logs ──────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  resource  String
  resourceId String?
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── In-app notifications ────────────────────────────────────────────
//
// Persisted feed entries backing the dashboard bell. One row per
// recipient — "global" events (deploy outcome, SSL, backup, alert)
// fan out to every active ADMIN/SUPERADMIN at dispatch time so each
// recipient tracks their own read state. userId is nullable to allow
// admin-wide broadcast rows in the future.
model Notification {
  id        String    @id @default(cuid())
  userId    String?
  type      String
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("notifications")
}

// ─── Cron jobs ───────────────────────────────────────────────────────
//
// User-scheduled command that runs INSIDE an application's container on a
// standard 5-field cron expression. Works uniformly for Docker apps and PHP
// sites (both are containers): the scheduler resolves the app's container and
// runs the command via `docker exec` (local) or an EXEC agent task (remote) —
// the exact primitive ApplicationOpsService.execCommand already wires.
//
// The single API process is the only scheduler (no leader election); a 60s
// tick + a lastRunAt watermark (compared against previousOccurrence) decides
// what's due. Granularity is one minute; a run missed while the API was down
// is skipped, not caught up (lastRunAt jumps forward on the next tick).
model CronJob {
  id            String   @id @default(cuid())
  name          String
  // Standard 5-field cron expression (validated against the cron parser).
  schedule      String
  // Shell command run as `sh -c <command>` inside the app container.
  command       String
  enabled       Boolean  @default(true)
  // Watermark: the occurrence already honoured. NULL = never run (createdAt
  // is used as the floor so a brand-new job doesn't fire for past occurrences).
  lastRunAt     DateTime?
  // Outcome of the most recent run, surfaced in the dashboard.
  lastExitCode  Int?
  lastOutput    String?
  applicationId String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("cron_jobs")
}
