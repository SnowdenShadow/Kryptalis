coverage/

# Docker
docker/data/

# Runtime DockControl
apps/api/.dockcontrol/
# Auto-managed Caddy port-publish override (now lives under .dockcontrol; the
# old install location was the repo root — ignore both so a generated file is
# never committed).
.dockcontrol/docker-compose.override.yml
docker-compose.override.yml
# Legacy runtime dir (pre-rename) — may still be on disk on old installs until
# `docker compose down`. Kept ignored so stale DKIM/secrets aren't committed.
apps/api/.kryptalis/
*.sock
*.lock

graphify-out/
.claude/
.claude/settings.json

# Playwright
apps/dashboard/test-results/
apps/dashboard/playwright-report/