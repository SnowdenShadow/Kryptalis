{
  "name": "kryptalis",
  "version": "0.1.0",
  "private": true,
  "description": "The next-generation self-hosted infrastructure platform",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "dev:api": "pnpm --filter @kryptalis/api dev",
    "dev:dashboard": "pnpm --filter @kryptalis/dashboard dev",
    "build:api": "pnpm --filter @kryptalis/api build",
    "build:dashboard": "pnpm --filter @kryptalis/dashboard build",
    "db:generate": "pnpm --filter @kryptalis/api db:generate",
    "db:migrate": "pnpm --filter @kryptalis/api db:migrate",
    "db:push": "pnpm --filter @kryptalis/api db:push",
    "db:studio": "pnpm --filter @kryptalis/api db:studio",
    "docker:up": "docker compose -f docker/docker-compose.dev.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.dev.yml down",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "prettier": "^3.0.0",
    "turbo": "^2.3.3"
  }
}
